{
  "manifest_version": 3,
  "name": "Chess.com Stockfish Helper",
  "version": "2.0",
  "description": "Highlights the best chess moves on chess.com using a local Stockfish engine.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://*.chess.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.chess.com/*"],
      "js": ["content.js"]
    }
  ]
}
